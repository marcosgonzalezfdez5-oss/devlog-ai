# Which provider the Deep Agent's chat model factory resolves to by default.
# One of: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Per-provider model names (only the one matching LLM_PROVIDER needs a valid key below).
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-flash

# Per-provider API keys. Never commit real values.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Path to the System Under Test the agent analyzes (defaults to ../task_manager).
SUT_REPO_PATH=../task_manager

# Where generated QA reports are written (defaults to ./docs/reports).
REPORTS_DIR=./docs/reports

LOG_LEVEL=INFO
