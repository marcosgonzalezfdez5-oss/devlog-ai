{
  "name": "devlogai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "tsx watch src/webhook/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "start:web": "node --import tsx/esm src/webhook/index.ts",
    "start:worker": "node --import tsx/esm src/worker/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@hono/node-server": "^1.13.7",
    "@octokit/app": "^15.1.1",
    "@octokit/rest": "^21.1.1",
    "bullmq": "^5.51.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.11",
    "ioredis": "^5.6.1",
    "js-yaml": "^4.1.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.18",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
